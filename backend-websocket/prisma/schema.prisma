generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Deployment {
  id                    String                @id
  userId                String
  repositoryId          String
  serverId              String
  commitSha             String
  branch                String
  status                DeploymentStatus
  triggerType           TriggerType
  startedAt             DateTime              @default(now())
  completedAt           DateTime?
  duration              Int?
  RepositoryIntegration RepositoryIntegration @relation(fields: [repositoryId], references: [id])
  Server                Server                @relation(fields: [serverId], references: [id])
  user                  user                  @relation(fields: [userId], references: [id])
  DeploymentLog         DeploymentLog[]
}

model DeploymentConfig {
  id                    String                @id
  repositoryId          String
  serverId              String
  branch                String
  autoDeploy            Boolean               @default(true)
  dockerfilePath        String
  containerName         String
  environment           DeploymentEnvironment
  buildCommand          String?
  runCommand            String?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime
  RepositoryIntegration RepositoryIntegration @relation(fields: [repositoryId], references: [id])
  Server                Server                @relation(fields: [serverId], references: [id])

  @@unique([repositoryId, serverId, environment])
}

model DeploymentLog {
  id           String     @id
  deploymentId String
  level        LogLevel
  message      String
  createdAt    DateTime   @default(now())
  Deployment   Deployment @relation(fields: [deploymentId], references: [id], onDelete: Cascade)
}

model RepositoryIntegration {
  id               String             @id
  userId           String
  githubRepoId     BigInt
  owner            String
  repoName         String
  fullName         String
  webhookId        BigInt
  createdAt        DateTime           @default(now())
  updatedAt        DateTime
  status           WebhookStatus
  cloneUrl         String
  defaultBranch    String
  sshCloneUrl      String
  Deployment       Deployment[]
  DeploymentConfig DeploymentConfig[]
  user             user               @relation(fields: [userId], references: [id])

  @@unique([userId, githubRepoId])
}

model Server {
  id               String             @id
  userId           String
  name             String
  host             String
  port             Int                @default(22)
  username         String
  privateKey       String
  createdAt        DateTime           @default(now())
  updatedAt        DateTime
  Deployment       Deployment[]
  DeploymentConfig DeploymentConfig[]
  user             user               @relation(fields: [userId], references: [id])
}

model account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime
  user                  user      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      user     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model user {
  id                    String                  @id
  name                  String
  email                 String                  @unique
  emailVerified         Boolean                 @default(false)
  image                 String?
  createdAt             DateTime                @default(now())
  updatedAt             DateTime
  Deployment            Deployment[]
  RepositoryIntegration RepositoryIntegration[]
  Server                Server[]
  account               account[]
  session               session[]
}

model verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime

  @@index([identifier])
}

enum DeploymentEnvironment {
  DEVELOPMENT
  STAGING
  PRODUCTION
}

enum DeploymentStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
  ROLLBACK
}

enum LogLevel {
  INFO
  WARNING
  ERROR
}

enum TriggerType {
  WEBHOOK
  MANUAL
}

enum WebhookStatus {
  RUNNING
  STOP
}
